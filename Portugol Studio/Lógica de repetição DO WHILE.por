programa
{
	
	funcao inicio()
	{
				
		
		inteiro num, produto, cont
	
		cont= 0
		
		faca {
			escreva ("Digite um número: ")
			leia(num)
			produto = num * 3
			escreva("Multiplicação = "  , produto,"\n")
			cont = cont + 0
			escreva( "contador = ", cont, "\n")
			
					}
		enquanto (cont <5 )
		
	}
}
